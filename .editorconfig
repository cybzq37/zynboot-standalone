# EditorConfig - 统一编辑器格式
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

[*.java]
indent_size = 4

[*.xml]
indent_size = 2

[*.{yml,yaml}]
indent_size = 2

[*.{json,js,ts,css,html}]
indent_size = 2

[*.md]
indent_size = 2
trim_trailing_whitespace = false

[Dockerfile]
indent_size = 4

[Makefile]
indent_style = tab
